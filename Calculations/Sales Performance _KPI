Total Volume Discount = 
VAR UnitSold = [Unit Sold]
VAR ThresholdValue = 150
VAR CostperUnit = [Cost/Unit]
RETURN
if(
    UnitSold > ThresholdValue, 
   CostperUnit*0.1,
    BLANK()
)
 // Discount provided by vendors to business on cost of products on selling more than the set thresholds which is 150 as of now on a monthly basis.

___________________________________________________________________________________________________________________________________________________

Excess Amount = 
VAR UnitSOld = [Unit Sold]
VAR Discount = 0.1
VAR ThresholdValue = 150
RETURN
if(
    UnitSOld > ThresholdValue, 
    UnitSOld-ThresholdValue
)
